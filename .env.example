# Subunit Bridge Daemon — Environment

# Server
PORT=7842
HOST=127.0.0.1

# Upstream Subunit Services
AUTH_BASE_URL=https://auth.subunit.ai
API_BASE_URL=https://api.subunit.ai
WS_BASE_URL=wss://ws.subunit.ai

# Local state directory (overridable for testing)
# Default: $XDG_DATA_HOME/subunit-bridge or ~/.local/share/subunit-bridge
STATE_DIR=

# Client identifier used for OAuth + Audit
CLIENT_ID=bridge-daemon
